# =============================================================================
# American Seekers Academy — Environment Variables
# Copy this file to .env (or configure in Replit Secrets) and fill in values.
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED — Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require
# Neon serverless connection string. Provision via Replit Database or Neon.

# -----------------------------------------------------------------------------
# REQUIRED FOR ADMIN — Admin Dashboard Access
# -----------------------------------------------------------------------------
ADMIN_PASSWORD=your-secure-admin-password-here
# Used for the simple shared-password login at /admin and /blog/admin.

# -----------------------------------------------------------------------------
# REQUIRED FOR EMAIL — SendGrid (Primary Email Provider)
# -----------------------------------------------------------------------------
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Get from https://app.sendgrid.com/settings/api_keys
#
# IMPORTANT:
# - The address "contact@americanseekersacademy.com" (or your chosen from address)
#   MUST be added as a Verified Sender in SendGrid, OR you must authenticate
#   the domain.
# - All transactional emails (contact notifications, program PDFs, waitlist
#   confirmations, location suggestions) are sent through SendGrid as raw HTML.
# - No HubSpot transactional templates are used.

# -----------------------------------------------------------------------------
# OPTIONAL — HubSpot CRM (Contact Upsert Only)
# -----------------------------------------------------------------------------
HUBSPOT_API=pat-na1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# HubSpot Private App access token.
# Only needed if you want form submissions to also create/update contacts in
# HubSpot CRM.
#
# Required scopes on the Private App:
#   - crm.objects.contacts.write
#
# This integration is best-effort and non-blocking. Email delivery does NOT
# depend on HubSpot.

# -----------------------------------------------------------------------------
# OPTIONAL — Development / Replit Specific
# -----------------------------------------------------------------------------
# REPL_ID=your-repl-id
# NODE_ENV=development
# REPLIT_DEV_DOMAIN=your-repl-name.username.repl.co

# -----------------------------------------------------------------------------
# OPTIONAL — Analytics Rate Limiting (public /api/analytics/pageview)
# -----------------------------------------------------------------------------
# ANALYTICS_RATE_LIMIT=40
# ANALYTICS_RATE_WINDOW_MINUTES=5
#
# Protects the page_views table from spam. Defaults are generous for a
# marketing site (40 pageviews per 5-minute window per IP).
# When a client exceeds the limit, the server still returns success (so the
# frontend is unaffected) but skips writing the record to the database.

# ADMIN_LOGIN_RATE_LIMIT=5
# ADMIN_LOGIN_RATE_WINDOW_MINUTES=15
#
# Brute-force protection for the admin login endpoint.
# After too many failed attempts from the same IP, further logins are blocked
# temporarily (HTTP 429). Defaults are reasonably strict for a shared password system.
